// =============================================================================
//  Edge Case: Arithmetic edge cases (การคำนวณกรณีพิเศษ)
//  Expected output:
//    0
//    0
//    -5
//    100
//    1
//    complex passed
// =============================================================================

// ศูนย์
set zero as int to 0
show zero

// คูณด้วยศูนย์
set result as int to 42 * 0
show result

// ค่าลบ
set neg as int to 0 - 5
show neg

// วงเล็บซ้อน
set paren as int to (2 + 3) * (4 + 16)
show paren

// Operator precedence
set prec as int to 2 + 3 * 4 - 13
show prec

show "complex passed"
