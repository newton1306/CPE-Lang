// =============================================================================
//  Test Case: Nested While Loops
// =============================================================================
//
//  ผู้รับผิดชอบ: [Testing Developer]
//  Branch: feature/testing
//
//  📋 Requirement:
//  - ทดสอบ while ซ้อน while (nested loops)
//  - ตรวจสอบว่าตัวแปร counter ใน loop ชั้นในถูก reset ทุกรอบของ loop ชั้นนอก
//  - ตรวจสอบว่า assignment ใน child scope (loop body) update ตัวแปรจาก parent ได้
//
//  🎯 Expected Output:
//  (กำหนดเองตาม test case — แนะนำทำตาราง i*j เล็กๆ เช่น 1-3)
//
//  💡 Hint:
//  - สร้าง outer loop: i = 1 to 3
//  - สร้าง inner loop: j = 1 to 3
//  - คำนวณ result = i * j แล้ว show
//  - ผลลัพธ์ควรเป็น: 1, 2, 3, 2, 4, 6, 3, 6, 9
//
//  สิ่งที่ต้องทดสอบ:
//  ✅ while ซ้อน while ทำงานถูกต้อง
//  ✅ ตัวแปร inner loop ถูก re-declare ทุกรอบ
//  ✅ counter ของ outer loop ถูก increment ถูกต้อง
//  ✅ ทุก loop ปิดด้วย end
//
//  TODO: เขียน test case ตามที่ระบุด้านบน
// =============================================================================

//ทดสอบ while loop ซ้อนขณะ (Nested Loops) เพื่อสร้างสูตรคูณย่อย
set i as int to 1

while i < 4 do
    //ต้องกำหนด j ใหม่ (Reset) ทุกครั้งที่เริ่ม Loop ชั้นนอกรอบใหม่
    set j as int to 1
    
    while j < 4 do
        //ทดสอบการอ่านค่า i จาก scope นอก และ j จาก scope ใน
        set result as int to i * j
        show result
        
        //Update counter ชั้นใน
        set j to j + 1
    end
    
    //Update counter ชั้นนอก
    set i to i + 1
end

//Output : 1 2 3 2 4 6 3 6 9
