// =============================================================================
//  Edge Case: Nested While loops (while ซ้อน while)
//  Expected output: Multiplication table 1-3
//    1 x 1 = 1
//    1 x 2 = 2
//    1 x 3 = 3
//    2 x 1 = 2
//    2 x 2 = 4
//    2 x 3 = 6
//    3 x 1 = 3
//    3 x 2 = 6
//    3 x 3 = 9
//    done
// =============================================================================

set i as int to 1

while i < 4 do
    set j as int to 1
    while j < 4 do
        set result as int to i * j
        show result
        set j to j + 1
    end
    set i to i + 1
end

show "done"
